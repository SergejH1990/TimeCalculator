<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".views.TimeCalculatorTextView">

        <TextView
            android:id="@+id/years_text_view"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="0dp"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textColor="@color/white"
            app:layout_constraintBottom_toTopOf="@+id/days_linear_layout"/>

        <LinearLayout
            android:id="@+id/days_linear_layout"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@+id/years_text_view">

            <CheckBox
                android:id="@+id/years_checkbox"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@color/black"/>

            <TextView
                android:id="@+id/days_text_view"
                android:layout_width="fill_parent"
                android:layout_height="50dp"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textSize="20sp" />
        </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>