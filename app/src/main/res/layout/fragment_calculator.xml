<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.calculator.CalculatorFragment">

    <com.sermut.timecalculator.views.TimeCalculatorView
        android:id="@+id/time_calculator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:layout_constraintBottom_toTopOf="@id/result_calculator_text" />

    <com.sermut.timecalculator.views.TimeCalculatorTextView
        android:id="@+id/result_calculator_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/teal_200"
        app:layout_constraintTop_toBottomOf="@id/time_calculator"/>

</androidx.constraintlayout.widget.ConstraintLayout>